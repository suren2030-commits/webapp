PORT=3000

# MySQL (host.docker.internal = Windows host from inside Kubernetes)
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=webapp_db

# ClickHouse (in-cluster DNS)
CLICKHOUSE_URL=http://clickhouse.clickhouse.svc.cluster.local:8123
CLICKHOUSE_USER=apoc_user
CLICKHOUSE_PASSWORD=apoc123
CLICKHOUSE_DATABASE=apoc_analytics

# Keycloak (in-cluster DNS)
KEYCLOAK_URL=http://keycloak.keycloak.svc.cluster.local
KEYCLOAK_REALM=master

# CORS — frontend origin
CORS_ORIGIN=http://airport.ops
